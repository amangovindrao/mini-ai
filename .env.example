# JARVIS-AI  |  Phase X  |  .env.example
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
DB_PATH=./database/jarvis.db
CHROMA_PATH=./database/chroma
WHISPER_MODEL=small
MALE_VOICE_MODEL=./models/male_voice/best_model.pth
FEMALE_VOICE_MODEL=./models/female_voice/best_model.pth
FACE_SCAN_TIMEOUT=12
FACE_CONFIDENCE_THRESHOLD=0.85
LIBRETRANSLATE_URL=http://localhost:5000
ADMIN_USER_ID=1
BACKEND_PORT=8000
BACKUP_PATH=./backups/

# =========================
# OLLAMA
# =========================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# =========================
# DATABASE
# =========================
DB_PATH=./database/jarvis.db
CHROMA_PATH=./database/chroma

# =========================
# WHISPER
# =========================
WHISPER_MODEL=small

# =========================
# VOICE MODELS
# =========================
MALE_VOICE_MODEL=tts_models/en/ljspeech/tacotron2-DDC
# MALE_VOICE_MODEL=./models/male_voice/best_model.pth
FEMALE_VOICE_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# =========================
# FACE RECOGNITION
# =========================
FACE_SCAN_TIMEOUT=12
FACE_CONFIDENCE_THRESHOLD=0.85

# =========================
# TRANSLATION
# =========================
# LIBRETRANSLATE_URL=http://localhost:5000

# =========================
# SYSTEM
# =========================
ADMIN_USER_ID=1
BACKEND_PORT=8000
BACKUP_PATH=./backups/